# Dependencies
node_modules/

# Build output
frontend/dist/

# Sensitive config files (use *.example.json as templates)
config/mqtt.json
config/homeassistant.json
config/pages/

# Runtime data
config/notifications.json
config/notification_events.json

# Sounds (add your own)
sounds/alert_sounds/*
sounds/speech_sounds/*
!sounds/alert_sounds/.gitkeep
!sounds/speech_sounds/.gitkeep

# Environment
.env

# Victron GUI v2 binaries
frontend/public/guiv2/*.wasm
frontend/public/guiv2/*.wasm.gz
frontend/public/guiv2/*.wasm.sha256
frontend/public/guiv2/*.wasm.size
frontend/public/guiv2/venus-gui-v2.js
frontend/public/guiv2/qtloader.js

# OS
.DS_Store
